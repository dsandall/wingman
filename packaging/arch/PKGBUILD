# Maintainer: Dylan Sandall <thebudman6@proton.me>
pkgname=wingman
pkgver=0.1.4
pkgrel=1
pkgdesc="Run multiple NetBird instances on one machine with isolated configs, sockets, and interfaces"
arch=('any')
url="https://github.com/dsandall/wingman"
license=('MIT')
# netbird is provided by the AUR package of the same name (wingman shells out
# to the `netbird` binary and is non-functional without it).
depends=('python' 'python-typer' 'netbird')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-hatchling' 'git')
# Builds the tip of master. To pin a tagged release instead, swap for:
#   source=("$pkgname::git+https://github.com/dsandall/wingman.git#tag=v$pkgver")
source=("$pkgname::git+https://github.com/dsandall/wingman.git#branch=master")
sha256sums=('SKIP')

build() {
	cd "$srcdir/$pkgname"
	python -m build --wheel --no-isolation
}

package() {
	cd "$srcdir/$pkgname"
	python -m installer --destdir="$pkgdir" dist/*.whl
	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
	install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
